---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const {
  title,
  description = 'A research environment for working scholars. Flexible doctoral programmes, world-class supervision, and industry-connected innovation.',
  ogImage = '/assets/images/og/home.jpg',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://doctoralcollege.org');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#030712" />
  <link rel="canonical" href={canonicalURL} />
  <title>{title} | Doctoral College UK</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={`${title} | Doctoral College UK`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Doctoral College UK" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Doctoral College UK`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body class="bg-bg text-white font-sans">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 bg-accent text-white px-4 py-2 rounded z-50">Skip to content</a>

  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 border-b border-border/60 bg-bg/90 backdrop-blur-md">
    <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="28" height="28" rx="6" fill="#3b82f6"/>
          <path d="M7 8h7a7 7 0 0 1 0 14H7V8z" fill="white" opacity="0.9"/>
          <circle cx="19" cy="10" r="3" fill="white" opacity="0.5"/>
        </svg>
        <span class="text-sm font-semibold leading-tight">
          <span class="text-white">Doctoral College</span><br/>
          <span class="text-muted-light text-xs font-normal">UK</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-6">
        <a href="/" class="nav-link">Home</a>
        <a href="/about/" class="nav-link">About</a>

        <!-- Programmes dropdown -->
        <div class="nav-item relative">
          <button class="nav-link flex items-center gap-1">
            Programmes
            <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M2 4l4 4 4-4"/></svg>
          </button>
          <div class="nav-dropdown">
            <a href="/programmes/access-to-doctorate/">Access to Doctorate <span>Foundational pathway into doctoral study</span></a>
            <a href="/programmes/mphil/">MPhil / SCQF <span>Research masters with SCQF credit</span></a>
            <a href="/programmes/online-phd/">Online PhD <span>Flexible doctorate for working professionals</span></a>
            <a href="/programmes/dba/">DBA <span>Doctor of Business Administration</span></a>
            <a href="/programmes/edd/">EdD <span>Doctor of Education</span></a>
            <a href="/programmes/research-training/">Research Training <span>Methodology and skills development</span></a>
            <a href="/programmes/supervisor-development/">Supervisor Development <span>Training for doctoral supervisors</span></a>
            <a href="/fees/">Fees &amp; Funding <span>Every number upfront</span></a>
          </div>
        </div>

        <!-- Research dropdown -->
        <div class="nav-item relative">
          <button class="nav-link flex items-center gap-1">
            Research
            <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M2 4l4 4 4-4"/></svg>
          </button>
          <div class="nav-dropdown">
            <a href="/research/strategy/">Strategy <span>Our research vision and priorities</span></a>
            <a href="/research/themes/">Themes <span>Twelve themed research areas</span></a>
            <a href="/research/current/">Research underway <span>Theses in progress across the college</span></a>
            <a href="/supervisors/">Supervisors <span>Find the right supervisor for your research</span></a>
            <a href="/research/publications/">Publications <span>Archive of papers and reports</span></a>
            <a href="/research/case-studies/">Case Studies <span>Industry impact in practice</span></a>
            <a href="/research/consultancy/">Consultancy <span>Commissioned research services</span></a>
          </div>
        </div>

        <a href="/symposium/" class="nav-link">Symposium</a>
        <a href="/experience/" class="nav-link">Experience</a>
        <a href="/connect/" class="nav-link">Connect</a>
      </div>

      <div class="flex items-center gap-3">
        <a href="/apply/" class="btn-primary hidden lg:inline-block">Apply Now</a>
        <!-- Mobile hamburger -->
        <button id="menu-toggle" class="lg:hidden p-2 text-muted-light hover:text-white" aria-label="Toggle menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 5h14v1.5H3V5zm0 4.5h14V11H3V9.5zM3 14h14v1.5H3V14z"/></svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="lg:hidden border-t border-border bg-bg/95 backdrop-blur-md px-6 py-4">
      <div class="space-y-1">
        <a href="/" class="block py-2 text-sm text-muted-light hover:text-white">Home</a>
        <a href="/about/" class="block py-2 text-sm text-muted-light hover:text-white">About</a>
        <div class="pt-2 pb-1"><p class="text-xs text-muted uppercase tracking-wider">Programmes</p></div>
        <a href="/programmes/access-to-doctorate/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Access to Doctorate</a>
        <a href="/programmes/mphil/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">MPhil / SCQF</a>
        <a href="/programmes/online-phd/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Online PhD</a>
        <a href="/programmes/dba/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">DBA</a>
        <a href="/programmes/edd/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">EdD</a>
        <a href="/programmes/research-training/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Research Training</a>
        <a href="/programmes/supervisor-development/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Supervisor Development</a>
        <a href="/fees/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Fees &amp; Funding</a>
        <div class="pt-2 pb-1"><p class="text-xs text-muted uppercase tracking-wider">Research</p></div>
        <a href="/research/strategy/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Strategy</a>
        <a href="/research/themes/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Themes</a>
        <a href="/research/current/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Research underway</a>
        <a href="/supervisors/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Supervisors</a>
        <a href="/research/publications/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Publications</a>
        <a href="/research/case-studies/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Case Studies</a>
        <a href="/research/consultancy/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-white">Consultancy</a>
        <a href="/symposium/" class="block py-2 text-sm text-muted-light hover:text-white">Symposium</a>
        <a href="/experience/" class="block py-2 text-sm text-muted-light hover:text-white">Experience</a>
        <a href="/connect/" class="block py-2 text-sm text-muted-light hover:text-white">Connect</a>
        <div class="pt-3">
          <a href="/apply/" class="btn-primary w-full text-center">Apply Now</a>
        </div>
      </div>
    </div>
  </header>

  <main id="main-content" class="pt-16">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-border mt-24">
    <!-- CTA strip -->
    <div class="border-b border-border bg-surface/40">
      <div class="max-w-7xl mx-auto px-6 py-8 flex flex-wrap gap-4 items-center justify-between">
        <div class="flex flex-wrap gap-3">
          <a href="/apply/" class="btn-primary">Apply</a>
          <a href="/connect/" class="btn-outline">Book</a>
          <a href="/assets/prospectus.pdf" class="btn-outline">Prospectus</a>
          <a href="/symposium/" class="btn-outline">Webinar</a>
        </div>
        <!-- Newsletter -->
        <form class="flex gap-2" onsubmit="return false;">
          <input type="email" placeholder="Monthly digest — enter your email" class="bg-surface border border-border rounded-md px-4 py-2 text-sm text-white placeholder:text-muted focus:outline-none focus:border-accent w-64" />
          <button type="submit" class="btn-primary">Subscribe</button>
        </form>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12">
        <!-- Brand -->
        <div class="lg:col-span-2">
          <a href="/" class="flex items-center gap-2.5 mb-4">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="28" height="28" rx="6" fill="#3b82f6"/>
              <path d="M7 8h7a7 7 0 0 1 0 14H7V8z" fill="white" opacity="0.9"/>
              <circle cx="19" cy="10" r="3" fill="white" opacity="0.5"/>
            </svg>
            <span class="text-sm font-semibold">Doctoral College UK</span>
          </a>
          <p class="text-sm text-muted-light leading-relaxed max-w-xs">Forward-thinking doctoral education, supervisor training, and research innovation in business and management.</p>
          <div class="flex gap-4 mt-6">
            <a href="https://www.linkedin.com/company/doctoralcollegeuk" target="_blank" rel="noopener" class="text-muted hover:text-white transition-colors" aria-label="LinkedIn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="https://x.com/doctoralcolluk" target="_blank" rel="noopener" class="text-muted hover:text-white transition-colors" aria-label="X / Twitter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://www.youtube.com/@doctoralcollegeuk" target="_blank" rel="noopener" class="text-muted hover:text-white transition-colors" aria-label="YouTube">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12z"/></svg>
            </a>
            <a href="https://www.instagram.com/doctoralcollegeuk" target="_blank" rel="noopener" class="text-muted hover:text-white transition-colors" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          </div>
        </div>

        <!-- Quick Links -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-muted mb-4">Quick Links</h3>
          <ul class="space-y-2.5">
            <li><a href="/about/" class="text-sm text-muted-light hover:text-white">About</a></li>
            <li><a href="/programmes/" class="text-sm text-muted-light hover:text-white">Programmes</a></li>
            <li><a href="/research/strategy/" class="text-sm text-muted-light hover:text-white">Research</a></li>
            <li><a href="/experience/" class="text-sm text-muted-light hover:text-white">Student Experience</a></li>
          </ul>
        </div>

        <!-- Training -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-muted mb-4">Training</h3>
          <ul class="space-y-2.5">
            <li><a href="/programmes/online-phd/" class="text-sm text-muted-light hover:text-white">Online PhD</a></li>
            <li><a href="/programmes/dba/" class="text-sm text-muted-light hover:text-white">DBA</a></li>
            <li><a href="/programmes/edd/" class="text-sm text-muted-light hover:text-white">EdD</a></li>
            <li><a href="/programmes/supervisor-development/" class="text-sm text-muted-light hover:text-white">Supervisor Development</a></li>
          </ul>
        </div>

        <!-- Events & Resources -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-muted mb-4">Events &amp; Resources</h3>
          <ul class="space-y-2.5">
            <li><a href="/symposium/" class="text-sm text-muted-light hover:text-white">Symposium</a></li>
            <li><a href="/news/" class="text-sm text-muted-light hover:text-white">News</a></li>
            <li><a href="/research/publications/" class="text-sm text-muted-light hover:text-white">Publications</a></li>
            <li><a href="/research/case-studies/" class="text-sm text-muted-light hover:text-white">Case Studies</a></li>
          </ul>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="mt-12 pt-8 border-t border-border flex flex-wrap gap-4 items-center justify-between">
        <p class="text-sm text-muted">&copy; 2026 Doctoral College UK. All rights reserved.</p>
        <div class="flex flex-wrap gap-4">
          <a href="/accessibility/" class="text-sm text-muted hover:text-white">Accessibility</a>
          <a href="/privacy/" class="text-sm text-muted hover:text-white">Privacy</a>
          <a href="/terms/" class="text-sm text-muted hover:text-white">Terms</a>
          <a href="/sitemap-page/" class="text-sm text-muted hover:text-white">Sitemap</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => menu?.classList.toggle('open'));

    // Animated counters
    function animateCounter(el: HTMLElement) {
      const target = parseInt(el.dataset.target || '0', 10);
      const suffix = el.dataset.suffix || '';
      const duration = 1500;
      const step = target / (duration / 16);
      let current = 0;
      const timer = setInterval(() => {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = Math.floor(current) + suffix;
      }, 16);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('[data-target]').forEach(el => observer.observe(el));
  </script>
</body>
</html>
