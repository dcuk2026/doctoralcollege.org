---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const {
  title,
  description = 'A research environment for working scholars. Flexible doctoral programmes, world-class supervision, and industry-connected innovation.',
  ogImage = '/assets/images/og/home.jpg',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://doctoralcollege.org');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#ffffff" />
  <link rel="canonical" href={canonicalURL} />
  <title>{title} | Doctoral College UK</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={`${title} | Doctoral College UK`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Doctoral College UK" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Doctoral College UK`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body class="bg-bg text-gray-900 font-sans">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 bg-accent text-white px-4 py-2 rounded z-50">Skip to content</a>

  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-white/95 backdrop-blur-md shadow-sm">
    <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <!-- Desktop nav -->
      <div class="hidden lg:flex flex-1 items-center justify-between mr-4">
        <a href="/" class="nav-link">Home</a>
        <a href="/about/" class="nav-link">About</a>
        <a href="/programmes/" class="nav-link">Programmes</a>
        <a href="/research/strategy/" class="nav-link">Research</a>
        <a href="/symposium/" class="nav-link">Symposium</a>
        <a href="/experience/" class="nav-link">Experience</a>
        <a href="/connect/" class="nav-link">Connect</a>
        <a href="/mydoctorate/" class="nav-link">MyDoctorate</a>
        <a href="/vle/" class="nav-link">VLE</a>
      </div>

      <div class="flex items-center gap-3">
        <a href="/apply/" class="hidden lg:inline-block text-white font-medium text-sm px-5 py-2.5 rounded-md transition-colors duration-200" style="background:#2563eb;" onmouseover="this.style.background='#1d4ed8'" onmouseout="this.style.background='#2563eb'">Apply Now</a>
        <!-- Mobile hamburger -->
        <button id="menu-toggle" class="lg:hidden p-2 text-muted-light hover:text-gray-900" aria-label="Toggle menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 5h14v1.5H3V5zm0 4.5h14V11H3V9.5zM3 14h14v1.5H3V14z"/></svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="lg:hidden border-t border-border bg-white px-6 py-4">
      <div class="space-y-1">
        <a href="/" class="block py-2 text-sm text-muted-light hover:text-gray-900">Home</a>
        <a href="/about/" class="block py-2 text-sm text-muted-light hover:text-gray-900">About</a>
        <div class="pt-2 pb-1"><p class="text-xs text-muted uppercase tracking-wider">Programmes</p></div>
        <a href="/programmes/access-to-doctorate/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Access to Doctorate</a>
        <a href="/programmes/mphil/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">MPhil / SCQF</a>
        <a href="/programmes/online-phd/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Online PhD</a>
        <a href="/programmes/dba/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">DBA</a>
        <a href="/programmes/edd/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">EdD</a>
        <a href="/programmes/research-training/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Research Training</a>
        <a href="/programmes/supervisor-development/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Supervisor Development</a>
        <a href="/fees/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Fees &amp; Funding</a>
        <div class="pt-2 pb-1"><p class="text-xs text-muted uppercase tracking-wider">Research</p></div>
        <a href="/research/strategy/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Strategy</a>
        <a href="/research/themes/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Themes</a>
        <a href="/research/current/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Research underway</a>
        <a href="/supervisors/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Supervisors</a>
        <a href="/research/publications/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Publications</a>
        <a href="/research/case-studies/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Case Studies</a>
        <a href="/research/consultancy/" class="block py-1.5 pl-3 text-sm text-muted-light hover:text-gray-900">Consultancy</a>
        <a href="/symposium/" class="block py-2 text-sm text-muted-light hover:text-gray-900">Symposium</a>
        <a href="/experience/" class="block py-2 text-sm text-muted-light hover:text-gray-900">Experience</a>
        <a href="/connect/" class="block py-2 text-sm text-muted-light hover:text-gray-900">Connect</a>
        <a href="/mydoctorate/" class="block py-2 text-sm text-muted-light hover:text-gray-900">MyDoctorate</a>
        <a href="/vle/" class="block py-2 text-sm text-muted-light hover:text-gray-900">VLE</a>
        <div class="pt-3">
          <a href="/apply/" class="w-full text-center text-white font-medium text-sm px-5 py-2.5 rounded-md block" style="background:#2563eb;">Apply Now</a>
        </div>
      </div>
    </div>
  </header>

  <!-- Sub-header banner -->
  <div class="pt-16">
    <div class="max-w-7xl mx-auto px-6">
      <img src="/dcuk-banner-v2.png" alt="Doctoral College UK — Advancing Knowledge, Developing Researchers, Creating Impact" class="w-full h-auto block rounded-xl" />
    </div>
  </div>

  <main id="main-content">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-border mt-24 bg-surface">
    <!-- CTA strip -->
    <div class="border-b border-border bg-surface-2">
      <div class="max-w-7xl mx-auto px-6 py-8 flex flex-wrap gap-4 items-center justify-between">
        <div class="flex flex-wrap gap-3">
          <a href="/apply/" class="btn-primary">Apply</a>
          <a href="/connect/" class="btn-outline">Book</a>
          <a href="/assets/prospectus.pdf" class="btn-outline">Prospectus</a>
          <a href="/symposium/" class="btn-outline">Webinar</a>
        </div>
        <!-- Newsletter -->
        <form class="flex gap-2" onsubmit="return false;">
          <input type="email" placeholder="Monthly digest — enter your email" class="bg-white border border-border rounded-md px-4 py-2 text-sm text-gray-900 placeholder:text-muted focus:outline-none focus:border-accent w-64" />
          <button type="submit" class="btn-primary">Subscribe</button>
        </form>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12">
        <!-- Brand -->
        <div class="lg:col-span-2">
          <a href="/" class="inline-block mb-4">
            <img src="/logo-v2.png" alt="Doctoral College UK" class="h-20 w-auto" />
          </a>
          <p class="text-sm text-muted-light leading-relaxed max-w-xs">Forward-thinking doctoral education, supervisor training, and research innovation in business and management.</p>
          <div class="flex gap-4 mt-6">
            <a href="https://www.linkedin.com/company/doctoralcollegeuk" target="_blank" rel="noopener" class="text-muted hover:text-gray-900 transition-colors" aria-label="LinkedIn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="https://x.com/doctoralcolluk" target="_blank" rel="noopener" class="text-muted hover:text-gray-900 transition-colors" aria-label="X / Twitter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://www.youtube.com/@doctoralcollegeuk" target="_blank" rel="noopener" class="text-muted hover:text-gray-900 transition-colors" aria-label="YouTube">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12z"/></svg>
            </a>
            <a href="https://www.instagram.com/doctoralcollegeuk" target="_blank" rel="noopener" class="text-muted hover:text-gray-900 transition-colors" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          </div>
        </div>

        <!-- Quick Links -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-4">Quick Links</h3>
          <ul class="space-y-2.5">
            <li><a href="/about/" class="text-sm text-muted-light hover:text-gray-900">About</a></li>
            <li><a href="/programmes/" class="text-sm text-muted-light hover:text-gray-900">Programmes</a></li>
            <li><a href="/research/strategy/" class="text-sm text-muted-light hover:text-gray-900">Research</a></li>
            <li><a href="/experience/" class="text-sm text-muted-light hover:text-gray-900">Student Experience</a></li>
          </ul>
        </div>

        <!-- Training -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-4">Training</h3>
          <ul class="space-y-2.5">
            <li><a href="/programmes/online-phd/" class="text-sm text-muted-light hover:text-gray-900">Online PhD</a></li>
            <li><a href="/programmes/dba/" class="text-sm text-muted-light hover:text-gray-900">DBA</a></li>
            <li><a href="/programmes/edd/" class="text-sm text-muted-light hover:text-gray-900">EdD</a></li>
            <li><a href="/programmes/supervisor-development/" class="text-sm text-muted-light hover:text-gray-900">Supervisor Development</a></li>
          </ul>
        </div>

        <!-- Events & Resources -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-4">Events &amp; Resources</h3>
          <ul class="space-y-2.5">
            <li><a href="/symposium/" class="text-sm text-muted-light hover:text-gray-900">Symposium</a></li>
            <li><a href="/news/" class="text-sm text-muted-light hover:text-gray-900">News</a></li>
            <li><a href="/research/publications/" class="text-sm text-muted-light hover:text-gray-900">Publications</a></li>
            <li><a href="/research/case-studies/" class="text-sm text-muted-light hover:text-gray-900">Case Studies</a></li>
          </ul>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="mt-12 pt-8 border-t border-border flex flex-wrap gap-4 items-center justify-between">
        <p class="text-sm text-muted">&copy; 2026 Doctoral College UK. All rights reserved.</p>
        <div class="flex flex-wrap gap-4">
          <a href="/accessibility/" class="text-sm text-muted hover:text-gray-900">Accessibility</a>
          <a href="/privacy/" class="text-sm text-muted hover:text-gray-900">Privacy</a>
          <a href="/terms/" class="text-sm text-muted hover:text-gray-900">Terms</a>
          <a href="/sitemap-page/" class="text-sm text-muted hover:text-gray-900">Sitemap</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => menu?.classList.toggle('open'));

    // Animated counters
    function animateCounter(el: HTMLElement) {
      const target = parseInt(el.dataset.target || '0', 10);
      const suffix = el.dataset.suffix || '';
      const duration = 1500;
      const step = target / (duration / 16);
      let current = 0;
      const timer = setInterval(() => {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = Math.floor(current) + suffix;
      }, 16);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('[data-target]').forEach(el => observer.observe(el));
  </script>
</body>
</html>
