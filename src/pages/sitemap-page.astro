---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sitemap | Doctoral College UK" description="A complete sitemap of the Doctoral College UK website, listing all pages by section.">

  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">

      <p class="section-label mb-4">Navigation</p>
      <h1 class="text-4xl font-bold mb-4">Sitemap</h1>
      <p class="text-muted mb-12">A complete listing of all pages on the Doctoral College UK website, organised by section.</p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

        <!-- Main -->
        <div>
          <h2 class="text-lg font-bold mb-4 border-b border-border pb-2">Main Pages</h2>
          <ul class="space-y-2">
            <li><a href="/" class="text-accent hover:underline text-sm">Home</a></li>
            <li><a href="/about" class="text-accent hover:underline text-sm">About DCUK</a></li>
            <li><a href="/experience" class="text-accent hover:underline text-sm">Student Experience</a></li>
            <li><a href="/apply" class="text-accent hover:underline text-sm">How to Apply</a></li>
            <li><a href="/fees" class="text-accent hover:underline text-sm">Fees &amp; Funding</a></li>
            <li><a href="/symposium" class="text-accent hover:underline text-sm">Annual Symposium</a></li>
            <li><a href="/connect" class="text-accent hover:underline text-sm">Connect with Us</a></li>
          </ul>
        </div>

        <!-- Programmes -->
        <div>
          <h2 class="text-lg font-bold mb-4 border-b border-border pb-2">Programmes</h2>
          <ul class="space-y-2">
            <li><a href="/programmes" class="text-accent hover:underline text-sm">All Programmes</a></li>
            <li><a href="/programmes/dba" class="text-accent hover:underline text-sm">Doctor of Business Administration (DBA)</a></li>
            <li><a href="/programmes/edd" class="text-accent hover:underline text-sm">Doctor of Education (EdD)</a></li>
            <li><a href="/programmes/online-phd" class="text-accent hover:underline text-sm">Online PhD</a></li>
            <li><a href="/programmes/mphil" class="text-accent hover:underline text-sm">MPhil / SCQF Level 11</a></li>
            <li><a href="/programmes/access-to-doctorate" class="text-accent hover:underline text-sm">Access to Doctorate</a></li>
            <li><a href="/programmes/research-training" class="text-accent hover:underline text-sm">Research Training</a></li>
            <li><a href="/programmes/supervisor-development" class="text-accent hover:underline text-sm">Supervisor Development</a></li>
          </ul>
        </div>

        <!-- Supervisors -->
        <div>
          <h2 class="text-lg font-bold mb-4 border-b border-border pb-2">Supervisors</h2>
          <ul class="space-y-2">
            <li><a href="/supervisors" class="text-accent hover:underline text-sm">All Supervisors</a></li>
            <li><a href="/supervisors/stanley-oliver" class="text-accent hover:underline text-sm">Prof. Stanley Oliver</a></li>
            <li><a href="/supervisors/zahra-salimi" class="text-accent hover:underline text-sm">Dr. Zahra Salimi</a></li>
            <li><a href="/supervisors/paul-oliver" class="text-accent hover:underline text-sm">Dr. Paul Oliver</a></li>
            <li><a href="/supervisors/liz-blower" class="text-accent hover:underline text-sm">Dr. Liz Blower</a></li>
          </ul>
        </div>

        <!-- Research -->
        <div>
          <h2 class="text-lg font-bold mb-4 border-b border-border pb-2">Research</h2>
          <ul class="space-y-2">
            <li><a href="/research/strategy" class="text-accent hover:underline text-sm">Research Strategy</a></li>
            <li><a href="/research/themes" class="text-accent hover:underline text-sm">Research Themes</a></li>
            <li><a href="/research/current" class="text-accent hover:underline text-sm">Current Theses</a></li>
            <li><a href="/research/publications" class="text-accent hover:underline text-sm">Publications</a></li>
            <li><a href="/research/case-studies" class="text-accent hover:underline text-sm">Case Studies</a></li>
            <li><a href="/research/consultancy" class="text-accent hover:underline text-sm">Research Consultancy</a></li>
          </ul>
        </div>

        <!-- News -->
        <div>
          <h2 class="text-lg font-bold mb-4 border-b border-border pb-2">News &amp; Insights</h2>
          <ul class="space-y-2">
            <li><a href="/news" class="text-accent hover:underline text-sm">All News</a></li>
            <li><a href="/news/director-dispatch-research-worth-doing" class="text-accent hover:underline text-sm">What management research is worth doing in 2026</a></li>
            <li><a href="/news/executive-research-emerging-trends" class="text-accent hover:underline text-sm">Executive Research: Emerging Trends 2026</a></li>
            <li><a href="/news/emerging-management-research-areas" class="text-accent hover:underline text-sm">Seven Emerging Management Research Areas</a></li>
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h2 class="text-lg font-bold mb-4 border-b border-border pb-2">Legal &amp; Policies</h2>
          <ul class="space-y-2">
            <li><a href="/privacy" class="text-accent hover:underline text-sm">Privacy Policy</a></li>
            <li><a href="/terms" class="text-accent hover:underline text-sm">Terms &amp; Conditions</a></li>
            <li><a href="/accessibility" class="text-accent hover:underline text-sm">Accessibility Statement</a></li>
            <li><a href="/sitemap-page" class="text-accent hover:underline text-sm">Sitemap</a></li>
          </ul>
        </div>

      </div>

    </div>
  </section>

</Layout>
