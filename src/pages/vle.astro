---
import Layout from '../layouts/Layout.astro';
---
<Layout title="VLE" description="Virtual Learning Environment — Doctoral College UK.">
  <section class="relative overflow-hidden border-b border-border">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-white pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-28 relative z-10">
      <p class="section-label mb-4">Doctoral College UK</p>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-4 max-w-2xl">VLE</h1>
      <p class="text-lg text-muted-light max-w-2xl leading-relaxed">Content coming soon.</p>
    </div>
  </section>
</Layout>
